  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health",
            ""
          ]
        },
        "description": "Backend health endpoint."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Breeds List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/breeds/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "breeds",
            ""
          ]
        },
        "description": "List seeded breeds."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('has items array', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(Array.isArray(body.items)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
